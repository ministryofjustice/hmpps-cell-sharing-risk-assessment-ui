# Local development env for running the frontend on the host (`npm run start:local`)
# against the dependencies running in Docker (`docker compose up --scale app=0`).
#
# Copy to `.env.local` (gitignored) and adjust if needed:
#   cp .env.local.example .env.local

PORT=3000
REDIS_ENABLED=false
TOKEN_VERIFICATION_ENABLED=false

# hmpps-auth is published on host port 8080 by docker-compose
HMPPS_AUTH_URL=http://localhost:8080/auth
HMPPS_AUTH_EXTERNAL_URL=http://localhost:8080/auth

# CSRA API is published on host port 8090 by docker-compose
CSRA_API_URL=http://localhost:8090

# prisoner-search WireMock stub is published on host port 8083 by docker-compose
PRISONER_SEARCH_API_URL=http://localhost:8083

INGRESS_URL=http://localhost:3000
NO_HTTPS=true
SESSION_SECRET=somesecretvalue

# Clients seeded by local-stack/auth-seed/V901__csra_local_clients.sql
AUTH_CODE_CLIENT_ID=hmpps-cell-sharing-risk-assessment-ui
AUTH_CODE_CLIENT_SECRET=clientsecret
CLIENT_CREDS_CLIENT_ID=hmpps-cell-sharing-risk-assessment-ui-system
CLIENT_CREDS_CLIENT_SECRET=clientsecret

ENVIRONMENT_NAME=local
