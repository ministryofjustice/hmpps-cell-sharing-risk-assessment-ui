{% macro card(params) %}
  {% if params.visible != false %}
    <li class="govuk-grid-column-one-third card-group__item">
      <div id="{{ params.id }}" class="card{% if params.clickable %} card--clickable{% endif %}" data-qa="{{ params['data-qa'] }}">
        <h2 class="govuk-heading-m card__heading">
          {%- if params.href %}
            <a class="govuk-link govuk-link--no-visited-state card__link" href="{{ params.href }}">{{ params.heading | safe }}</a>
          {%- else %}
            {{ params.heading }}
          {%- endif %}
        </h2>
        {%- if params.description %}
          <p class="govuk-body card__description">{{ params.description | safe }}</p>
        {%- endif %}
      </div>
    </li>
  {% endif %}
{% endmacro %}
