{% extends "govuk/template.njk" %}

{% from "../macros/breadcrumb.njk" import breadcrumb %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet"/>
  {% for css in feComponents.cssIncludes %}
    <link href="{{ css }}" nonce="{{ cspNonce }}" rel="stylesheet"/>
  {% endfor %}
{% endblock %}

{% block pageTitle %}{% if validationErrors %}Error: {% endif %}{{pageTitle | default(applicationName)}}{% endblock %}

{% block header %}
  {% if feComponents %}
    {{ feComponents.header | safe }}
  {% else %}
    {% include "./header.njk" %}
  {% endif %}
{% endblock %}

{% block footer %}
  {% if feComponents %}
    {{ feComponents.footer | safe }}
  {% endif %}
{% endblock %}

{% block bodyStart %}
{% endblock %}

{% block container %}
  <div class="app-container">
    {% block containerStart %}
      {% block beforeContent %}
        <div class="govuk-width-container">
          <div class="govuk-grid-row govuk-!-margin-bottom-0">
            <div class="govuk-grid-column-full">
              {% if backLink %}
                {% block backButton %}
                  {{ govukBackLink({
                    text: backLinkText or "Back",
                    href: backLink
                  }) }}
                {% endblock %}
              {% else %}
                {{ breadcrumb('', breadcrumbs, false) }}
              {% endif %}
            </div>
          </div>
        </div>
      {% endblock %}
    {% endblock %}

    {% block main %}
      <main class="govuk-main-wrapper" id="main-content" role="main">
        <div class="govuk-width-container">
          {% block outerHeading %}
            {% if validationErrors %}
              {% set errorList = [] %}
              {% for field, error in validationErrors %}
                {% set _ = errorList.push({ text: error.text, href: '#' + field }) %}
              {% endfor %}
              {{ govukErrorSummary({
                titleText: "There is a problem",
                errorList: errorList
              }) }}
            {% endif %}
            <div class="govuk-grid-row">
              <div class="govuk-grid-column-full">
                {% block heading %}
                  {% if titleCaption %}
                    <span class="govuk-caption-m" data-qa="title-caption">{{ titleCaption }}</span>
                  {% endif %}
                  <h1 class="govuk-heading-l">{{ title }}</h1>
                {% endblock %}
              </div>
            </div>
          {% endblock %}

          {% block content %}{% endblock %}
        </div>
      </main>
    {% endblock %}

    {% block containerEnd %}{% endblock %}
  </div>
{% endblock %}

{% block bodyEnd %}
  {% for js in feComponents.jsIncludes %}
    <script src="{{ js }}" nonce="{{ cspNonce }}"></script>
  {% endfor %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
{% endblock %}
